{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://phm.local/schemas/feature-window.schema.json",
  "title": "FeatureWindow",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion", "windowId", "machineId", "sourceSignalCodes",
    "windowStart", "windowEnd", "receivedAt", "features", "quality", "epoch"
  ],
  "properties": {
    "schemaVersion": {"const": "1.0"},
    "windowId": {"type": "string", "minLength": 1},
    "machineId": {"type": "string", "minLength": 1},
    "sourceSignalCodes": {
      "type": "array", "minItems": 1, "uniqueItems": true,
      "items": {"type": "string", "minLength": 1}
    },
    "windowStart": {"type": "string", "format": "date-time"},
    "windowEnd": {"type": "string", "format": "date-time"},
    "receivedAt": {"type": "string", "format": "date-time"},
    "features": {
      "type": "object", "minProperties": 1,
      "additionalProperties": {"type": "number"}
    },
    "quality": {"enum": ["good", "uncertain", "bad", "missing"]},
    "context": {
      "type": "object",
      "additionalProperties": {"type": ["string", "number", "boolean"]}
    },
    "epoch": {"type": "integer", "minimum": 1}
  }
}

